{
  "name": "raseen-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "serve": "^14.2.0"
  },
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build:frontend": "npm install && npm run build --workspace=raseen-frontend",
    "build:backend": "npm --workspace backend run build",
    "build": "npm run build:frontend && npm run build:backend",
    "lint": "npm --workspace frontend run lint && npm --workspace backend run lint",
    "prisma:generate": "npm --workspace backend run prisma:generate",
    "prisma:migrate": "npm --workspace backend run prisma:migrate",
    "seed": "npm --workspace backend run seed"
  }
}
